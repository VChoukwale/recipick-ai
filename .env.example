# ─── Supabase (Frontend) ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Data API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Supabase Edge Function Secrets ───────────────────────────────────────────
# Set these in: Supabase Dashboard → Edge Functions → Secrets
# DO NOT put these in this file — they are server-side only and never reach the browser.
#
# ANTHROPIC_API_KEY=sk-ant-...        (required — used by all AI edge functions)
# RESEND_API_KEY=re_...               (required — used by send-feedback for email)
